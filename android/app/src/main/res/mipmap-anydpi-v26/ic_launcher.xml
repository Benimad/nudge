<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- The logo PNG is full-bleed (its own purple field with the brain inside
       the safe zone), so no inset: an inset would expose a visible seam
       between the logo's gradient and the flat background color. -->
  <background android:drawable="@color/ic_launcher_background"/>
  <foreground android:drawable="@drawable/ic_launcher_foreground"/>
  <!-- Android 13+ themed icon: the hand-drawn safe-zone brain vector. -->
  <monochrome android:drawable="@drawable/ic_launcher_monochrome"/>
</adaptive-icon>
